{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "node",
    "baseUrl": "./",
    "jsx": "preserve",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@@/*": [
        ".dumi/tmp/*"
      ],
      "@rc-component/select": [
        "src/index.ts"
      ]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [
    ".dumirc.ts",
    "src",
    "tests",
    "docs"
  ]
}
